# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# OpenWeather API Key - Get from https://openweathermap.org/api
VITE_WEATHER_API_KEY="your_openweather_api_key_here"

# Firebase API Key - Get from Firebase Console
VITE_FIREBASE_API_KEY="your_firebase_api_key_here"

# ZenQuotes API Key - Optional, free tier doesn't require it
VITE_ZENQUOTES_API_KEY="your_zenquotes_api_key_here"